DATABASE_URL=postgresql+asyncpg://dreamland:secret@localhost:5432/dreamland
DATABASE_URL_SYNC=postgresql://dreamland:secret@localhost:5432/dreamland
ENVIRONMENT=development
SECRET_KEY=dev-secret-key-change-in-prod
DREAM_TOKEN_RATE_USD=0.15
MAX_TOKENS_PER_DAY=5
CONVERSION_FEE_RATE=0.02
AWS_REGION=ap-south-1

